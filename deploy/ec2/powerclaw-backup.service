[Unit]
Description=Back up PowerClaw SQLite state
After=powerclaw.service

[Service]
Type=oneshot
User=powerclaw
Group=powerclaw
EnvironmentFile=/etc/powerclaw/powerclaw.env
ExecStart=/usr/local/bin/powerclaw-backup-state
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/powerclaw /var/backups/powerclaw
StandardOutput=journal
StandardError=journal
