# PowerClaw EC2 environment template.
# Copy to /etc/powerclaw/powerclaw.env and set permissions to 600.

POWERCLAW_WORKSPACE_DIR=/var/lib/powerclaw/workspace
POWERCLAW_TRANSCRIPT_BACKEND=sqlite
POWERCLAW_RETRIEVAL_BACKEND=sqlite
POWERCLAW_SESSION_BACKEND=sqlite
POWERCLAW_PERMISSIONS_BACKEND=sqlite
POWERCLAW_OBSERVABILITY_BACKEND=sqlite
POWERCLAW_STATE_DB_PATH=/var/lib/powerclaw/state.db
POWERCLAW_BACKUP_DIR=/var/backups/powerclaw
POWERCLAW_BACKUP_RETENTION_DAYS=14

POWERCLAW_PROVIDER=openai
POWERCLAW_MODEL=gpt-5.4
OPENAI_API_KEY=replace-me

POWERCLAW_SERVER_HOST=127.0.0.1
POWERCLAW_SERVER_PORT=8765
POWERCLAW_AUTH_TOKEN=replace-with-a-long-random-token

POWERCLAW_ENABLE_REFLECTION=true
POWERCLAW_ENABLE_TERMINAL=false
POWERCLAW_TERMINAL_TRUSTED=false
POWERCLAW_TERMINAL_ALLOWED_COMMANDS=
POWERCLAW_TERMINAL_TIMEOUT_SECONDS=30
POWERCLAW_TERMINAL_MAX_OUTPUT_BYTES=24000
